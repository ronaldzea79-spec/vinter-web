---
// Definimos las propiedades (props) que nuestro componente va a recibir
interface Props {
  titulo: string;
  subtitulo: string;
  descripcion: string;
  numero: string;
}

const { titulo, subtitulo, descripcion, numero } = Astro.props;
---

<div class="bg-white p-8 rounded-2xl border border-slate-100 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 relative overflow-hidden group">
  <span class="absolute right-4 top-2 text-7xl font-bold text-slate-100/70 select-none group-hover:text-blue-50/70 transition-colors">
    {numero}
  </span>
  
  <div class="relative z-10 space-y-3">
    <div class="w-12 h-12 rounded-xl bg-blue-50 flex items-center justify-center text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-colors duration-300">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
      </svg>
    </div>
    
    <span class="text-xs font-semibold text-blue-600 tracking-wider uppercase block">{subtitulo}</span>
    <h3 class="text-xl font-bold text-slate-900">{titulo}</h3>
    <p class="text-slate-500 text-sm leading-relaxed">{descripcion}</p>
  </div>
</div>