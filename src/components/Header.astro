---
// src/components/Header.astro
interface Props {
  lang: 'es' | 'en';
}

const { lang } = Astro.props;

// Diccionario rápido local para los enlaces del menú
const menuText = {
  es: { catalogo: 'Catálogo', calidad: 'Calidad', contacto: 'Contacto', cambioLang: 'English', linkLang: '/en/' },
  en: { catalogo: 'Catalog', calidad: 'Quality', contacto: 'Contact', cambioLang: 'Español', linkLang: '/es/' }
};

const text = menuText[lang];
---

<header class="sticky top-0 z-50 w-full bg-blue-950/80 backdrop-blur-md border-b border-white/10 text-white">
  <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
    
    <!-- LOGO DE VINTER -->
    <a href={`/${lang}/`} class="flex items-center space-y-0 group">
      <span class="text-2xl font-black tracking-wider text-white group-hover:text-blue-400 transition-colors">
        VINTER
      </span>
      <span class="text-xs font-bold text-blue-400 ml-1 mt-2 font-mono">.ca</span>
    </a>

    <!-- MENÚ DE NAVEGACIÓN -->
    <nav class="hidden md:flex items-center space-x-8 text-sm font-medium">
      <a href="#catalogo" class="text-slate-300 hover:text-white transition-colors">{text.catalogo}</a>
      <a href="#certificaciones" class="text-slate-300 hover:text-white transition-colors">{text.calidad}</a>
      <a href="#contacto" class="text-slate-300 hover:text-white transition-colors">{text.contacto}</a>
    </nav>

    <!-- BOTÓN SELECTOR DE IDIOMA -->
    <div class="flex items-center space-x-4">
      <a 
        href={text.linkLang} 
        class="flex items-center space-x-1 text-xs font-semibold uppercase tracking-wider bg-white/10 hover:bg-blue-600 px-3 py-2 rounded-lg border border-white/10 transition-all duration-300"
      >
        <!-- Icono de Mundo / Idioma -->
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
        </svg>
        <span>{text.cambioLang}</span>
      </a>
    </div>

  </div>
</header>