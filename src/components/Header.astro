---
// src/components/Header.astro
interface Props {
  lang: 'es' | 'en';
}

const { lang } = Astro.props;

const menuText = {
  es: {
    rif: 'RIF: J-50158422-2',
    presencia: 'Presencia Nacional',
    catalogo: 'Catálogo',
    calidad: 'Calidad',
    contacto: 'Contacto',
    ctaBtn: 'Contactar',
    cambioLang: 'English',
    linkLang: '/en/'
  },
  en: {
    rif: 'RIF: J-50158422-2',
    presencia: 'National Presence',
    catalogo: 'Catalog',
    calidad: 'Quality',
    contacto: 'Contact',
    ctaBtn: 'Contact Us',
    cambioLang: 'Español',
    linkLang: '/es/'
  }
}[lang];
---

<!-- 
  CABECERA GLOBAL
  Cambiamos 'fixed' por 'absolute'. De este modo, el Top Bar y la Barra Flotante 
  se quedan anclados al inicio de la página y suben de forma natural con el scroll,
  dando exactamente esa sensación de que "se van perdiendo" hacia arriba.
-->
<header class="w-full absolute top-0 left-0 z-50 pointer-events-none">
  
  <!-- 1. TOP BAR ORIGINAL -->
  <div class="w-full text-white text-xs h-12 pointer-events-auto">
    <div class="max-w-7xl mx-auto px-6 h-full flex items-center justify-between font-mono">
      <div class="flex items-center space-x-6">
        <span class="font-medium text-white">{menuText.rif}</span>
        <span class="text-white/30">|</span>
        <span class="font-medium text-white">{menuText.presencia}</span>
      </div>
      <div>
        <a href={menuText.linkLang} class="flex items-center space-x-1 hover:text-blue-400 transition-colors uppercase tracking-wider font-bold text-white">
          <svg class="w-3.5 h-3.5 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
          </svg>
          <span>{menuText.cambioLang}</span>
        </a>
      </div>
    </div>
  </div>

  <!-- 2. MENÚ ESTADO DEFAULT: CAJA FLOTANTE PREMIUM -->
  <div class="w-full px-4 sm:px-6 pointer-events-auto">
    <div class="max-w-7xl mx-auto bg-white text-slate-900 rounded-2xl border border-slate-200/90 shadow-xl shadow-blue-950/10 h-20 flex items-center justify-between px-6">
      
      <!-- Orillo Blanco Corregido -->
      <a href={`/${lang}/`} class="flex items-center h-full -ml-6 overflow-hidden rounded-l-2xl border-y border-l border-blue-950">
        <div class="bg-blue-950 text-white h-20 px-8 flex items-center font-black tracking-wider text-xl">
          VINTER
        </div>
      </a>

      <nav class="hidden md:flex items-center space-x-8 text-sm font-bold tracking-wide uppercase text-slate-600">
        <a href="#catalogo" class="hover:text-blue-600 transition-colors">{menuText.catalogo}</a>
        <a href="#certificaciones" class="hover:text-blue-600 transition-colors">{menuText.calidad}</a>
        <a href="#contacto" class="hover:text-blue-600 transition-colors">{menuText.contacto}</a>
      </nav>

      <div class="flex items-center">
        <a href="#contacto" class="bg-blue-600 hover:bg-blue-700 text-white text-xs font-bold uppercase tracking-wider px-5 py-3 rounded-xl shadow-md transition-all">
          {menuText.ctaBtn}
        </a>
      </div>
    </div>
  </div>

</header>

<!-- 
  3. MENÚ ESTADO STICKY: BARRA FIJA PLANA 
  Esta barra SÍ es 'fixed'. Está completamente separada y oculta en el tope.
  Solo aparecerá bajando como una cortina cuando la barra flotante de arriba 
  se haya perdido completamente de vista.
-->
<div 
  id="menu-fijo" 
  class="w-full fixed top-0 left-0 z-50 bg-white text-slate-900 border-b border-slate-200 shadow-md h-20 transition-all duration-300 transform -translate-y-full opacity-0 pointer-events-none"
>
  <div class="max-w-7xl mx-auto px-6 h-full flex items-center justify-between">
    
    <a href={`/${lang}/`} class="flex items-center group">
      <span class="text-2xl font-black tracking-wider text-blue-950">VINTER</span>
      <span class="text-xs font-bold text-blue-600 ml-0.5 mt-2 font-mono">.ca</span>
    </a>

    <nav class="hidden md:flex items-center space-x-8 text-sm font-bold tracking-wide uppercase text-slate-600">
      <a href="#catalogo" class="hover:text-blue-600 transition-colors">{menuText.catalogo}</a>
      <a href="#certificaciones" class="hover:text-blue-600 transition-colors">{menuText.calidad}</a>
      <a href="#contacto" class="hover:text-blue-600 transition-colors">{menuText.contacto}</a>
    </nav>

    <div class="flex items-center">
      <a href="#contacto" class="bg-blue-950 hover:bg-slate-800 text-white text-xs font-bold uppercase tracking-wider px-5 py-3 rounded-lg shadow-md transition-all">
        {menuText.ctaBtn}
      </a>
    </div>
  </div>
</div>

<!-- LÓGICA DE DETECCIÓN DE SCROLL PARA LA BARRA FIJA -->
<script>
  const menuFijo = document.getElementById('menu-fijo');

  window.addEventListener('scroll', () => {
    if (!menuFijo) return;

    // Cuando el usuario baje lo suficiente (p. ej., pasando la altura del Header + margen = 180px)
    // la barra fija de pantalla completa desciende suavemente.
    if (window.scrollY > 180) {
      menuFijo.classList.remove('-translate-y-full', 'opacity-0', 'pointer-events-none');
      menuFijo.classList.add('translate-y-0', 'opacity-100', 'pointer-events-auto');
    } else {
      // Al volver arriba, se esconde limpiamente hacia arriba y deja ver la flotante estática.
      menuFijo.classList.remove('translate-y-0', 'opacity-100', 'pointer-events-auto');
      menuFijo.classList.add('-translate-y-full', 'opacity-0', 'pointer-events-none');
    }
  });
</script>